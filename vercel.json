{
  "installCommand": "npm install",
  "buildCommand": "turbo run build && node scripts/assemble.js",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/01-clerk-nav/(.*)",
      "destination": "/01-clerk-nav/index.html"
    },
    {
      "source": "/02-linear-issues/(.*)",
      "destination": "/02-linear-issues/index.html"
    }
  ]
}
